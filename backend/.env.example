# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexusnook

# Redis Cache
REDIS_URL=redis://localhost:6379

# Security (use a long random string in production, e.g. `openssl rand -base64 32`)
JWT_SECRET=change-this-to-a-very-long-random-string

# CORS
FRONTEND_URL=http://localhost:3000

# RSI Integration (Optional)
RSI_API_ENABLED=true
RSI_API_KEY=your-api-key-if-available
