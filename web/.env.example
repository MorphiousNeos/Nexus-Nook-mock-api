# Nexus Nook web app — environment variables
# Copy to `.env.local` for local dev. All Vite vars must start with VITE_.

# Optional. Base URL of the real backend (see docs/API.md), e.g. https://api.example.com
# If UNSET, the app runs in fully client-side "demo mode" (localStorage only).
VITE_API_URL=

# Optional. Full Discord invite URL for the "Join our Discord" button.
# If unset, the button is shown disabled with a "coming soon" tooltip.
VITE_DISCORD_INVITE=
