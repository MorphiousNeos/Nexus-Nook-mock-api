# iOS / Xcode specifics (in addition to repo-root .gitignore)

# Generated by XcodeGen — do not commit; run `xcodegen generate`
NexusNook.xcodeproj/

# Xcode user state / workspaces
*.xcworkspace
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# Build output
DerivedData/
build/
*.ipa
*.dSYM
*.dSYM.zip

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods / Carthage (unused, but ignored for safety)
Pods/
Carthage/Build/
